      "source": [
        "fib(10)"
      ],
      "id": "f2bce8e7",
      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "Faktorial:\n",
        "\n",
        "$$0! = 1$$\n",
        "\n",
        "$$n! = n * (n-1)!$$\n",
        "\n",
        "Contoh:\n",
        "\n",
        "\\begin{align*}\n",
        "5! &= 5 * 4! \\\\\n",
        "&= 5 * 4 * 3! \\\\\n",
        "&= 5 * 4 * 3 * 2! \\\\\n",
        "&= 5 * 4 * 3 * 2 * 1! \\\\\n",
        "&= 5 * 4 * 3 * 2 * 1 * 0! \\\\\n",
        "&= 5 * 4 * 3 * 2 * 1 * 1 \\\\\n",
        "&= 120\n",
        "\\end{align*}\n"
      ],
      "id": "468e4d7a"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "def fact(n):\n",
        "  if (n == 0):\n",
        "    return 1\n",
        "  else:\n",
        "    return n * fact(n-1)"
      ],
      "id": "9167c35d",
      "execution_count": null,
      "outputs": []
    },
